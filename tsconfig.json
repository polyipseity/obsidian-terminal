{
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "lib": ["dom", "es2024"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "dist",
    "paths": {
      "obsidian": ["./node_modules/@polyipseity/obsidian/obsidian.d.ts"]
    },
    "resolveJsonModule": true,
    "rootDirs": ["assets", "scripts", "src", "tests"],
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2018",
    "types": ["node"]
  },
  "exclude": ["node_modules", "dist"],
  "include": ["assets/**/*", "scripts/**/*", "src/**/*"]
}
